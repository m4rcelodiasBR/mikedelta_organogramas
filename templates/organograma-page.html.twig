{# Verifica se o usuário está logado para mostrar as ações de gerenciamento #}
{% if dados_organograma.is_logged_in %}
  <div class="container node-actions mb-3" style="padding-top: 20px;">
    <div class="row align-items-center justify-content-end">
      <div class="col-auto">
        <strong>AÇÕES <i class="fa-solid fa-circle-chevron-right"></i></strong>
      </div>
      <div class="col-auto">
        <a href="{{ dados_organograma.url_config }}" class="btn btn-sm btn-edit"><i class="fa-solid fa-gear"></i> GERENCIAR</a>
      </div>
    </div>
  </div>
{% endif %}

{# Título da Página #}
<h1 class="page-title mb-3">Organograma</h1>

{# Container do Organograma #}
<div class="organograma-wrapper bg-transparent" style="width: 100%; height: auto; overflow: visible; padding-top: 40px 0;">
  <div id="mikedelta-tree" style="width: 100%; height: 100%;"></div>
</div>